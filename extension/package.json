{
  "name": "S5LuaDebuggerAdaptor",
  "displayName": "S5 LuaDebugger Adaptor",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "S5LuaDebuggerSideBar",
          "title": "S5LuaDebugger Adaptor",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "S5LuaDebuggerSideBar": [
        {
          "type": "webview",
          "id": "S5LuaDebuggerAdaptor-toggle-view",
          "name": "Einstellungen"
        }
      ]
    },
    "commands": [
      {
        "command": "activateS5LuaDebuggerAdaptor",
        "title": "Activate S5LuaDebuggerAdaptor"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "precompile":"node utils/cleanOutput.js",
    "compile": "tsc -p ./",
    "postcompile":"node utils/copyPublicToOutput.js",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "typescript": "^7.0.2"
  }
}
