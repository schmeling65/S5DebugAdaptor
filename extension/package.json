{
  "name": "S5LuaDebuggerAdaptor",
  "displayName": "S5 LuaDebugger Adaptor",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "breakpoints": [
      {
        "language": "lua"
      }
    ],
    "debuggers": [
      {
        "type": "s5lua",
        "label": "S5 Lua Debug",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "absolute path to the SHoK executable"
              },
              "args": {
                "type": "array",
                "description": "command line parameters",
                "default": [
                  "-extra2"
                ]
              },
              "attachDelay": {
                "type": "number",
                "description": "startup delay",
                "default": 1
              }
            }
          },
          "attach": {}
        },
        "initialConfigurations": [
          {
            "type": "s5lua",
            "request": "launch",
            "program": "",
            "args": [
              "-extra2"
            ],
            "attachDelay": 1
          }
        ],
        "configurationSnippets": [
          {
            "label": "S5 Lua Debug: Launch",
            "description": "A new configuration for launching S5",
            "body": {
              "type": "s5lua",
              "request": "launch",
              "program": "",
              "args": [
                "-extra2"
              ],
              "attachDelay": 1
            }
          },
          {
            "label": "S5 Lua Debug: Attach",
            "description": "A new configuration for attaching to S5",
            "body": {
              "type": "s5lua",
              "request": "attach"
            }
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "S5LuaDebuggerSideBar",
          "title": "S5LuaDebugger Adaptor",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "S5LuaDebuggerSideBar": [
        {
          "type": "webview",
          "id": "S5LuaDebuggerAdaptor-toggle-view",
          "name": "Einstellungen"
        }
      ]
    },
    "commands": [
      {
        "command": "activateS5LuaDebuggerAdaptor",
        "title": "Activate S5LuaDebuggerAdaptor"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "precompile":"node utils/cleanOutput.js",
    "compile": "tsc -p ./",
    "postcompile":"node utils/copyPublicToOutput.js",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "typescript": "^7.0.2"
  }
}
